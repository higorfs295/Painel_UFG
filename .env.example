# Variáveis lidas pelo docker-compose (copie para .env na raiz). NÃO versione o .env real.
# Gere um segredo forte:  node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=troque-por-um-segredo-aleatorio-de-32+caracteres
POSTGRES_PASSWORD=painel
# Porta do Postgres no HOST. Troque se você já tem um Postgres na 5432.
DB_PORT=5432
# O Caddy do compose publica 8081 (http) e 8443 (https) porque 80/8080 costumam estar
# ocupados no Windows. Estas URLs são a BASE dos links de convite/reset: se estiverem
# erradas, o convite chega apontando para um endereço que não existe.
APP_URL=http://localhost:8081
CORS_ORIGIN=http://localhost:8081
