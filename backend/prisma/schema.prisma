// Modelo de dados completo — ver ESPECIFICACAO.md §6
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")   // em produção Neon: string COM pooler (…-pooler…?pgbouncer=true)
  directUrl = env("DIRECT_URL")     // conexão direta (sem pooler) p/ migrações; local = igual à de cima
}

enum Role {
  ADMIN
  USER
}

enum Nucleus {
  NC
  NE
}

enum ReqType {
  PRE
  CO
}

enum SubjectState {
  APPROVED
  SIMULATED
  ENROLLED
} // APPROVED=oficial · ENROLLED=cursando agora · SIMULATED=planejada · ausência = pendente

enum ExtraCategory {
  NC        // Núcleo Comum (reclassificação de um extra)
  NE        // Núcleo Específico obrigatório (reclassificação)
  OPT       // Optativa / NE optativa
  NL        // Núcleo Livre
  AC        // Atividade Complementar
  NONE      // registro (não soma)
}

enum ExtraStatus {
  PLANNED       // planejado — não soma
  IN_PROGRESS   // em andamento — soma só na projeção (como CURSANDO)
  DONE          // concluído — soma no oficial e na projeção
}

enum PeriodType {
  TERM
  BREAK
}

// Calendário acadêmico GLOBAL (RF-20 v2): entradas agendadas por data de início, geridas
// pelos admins e valendo para todos. O período corrente = última entrada com startsAt <= agora.
// Ex.: 06/07 inicia BREAK (férias) -> 10/08 inicia TERM "2026.2" -> ...
model AcademicPeriod {
  id        String     @id @default(cuid())
  type      PeriodType
  term      String?    // "2026.2" quando TERM; null em BREAK
  startsAt  DateTime   @unique
  createdAt DateTime   @default(now())
  @@index([startsAt])
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String?                          // null até o usuário definir a própria senha (RF-02)
  role         Role     @default(USER)
  theme        String   @default("dark")          // validado como "dark"|"light" no zod da rota
  matricula    String?                            // nº de matrícula do aluno (opcional, RF-01)
  shift        String?                            // turno: matutino|vespertino|noturno|integral (aluno)
  createdAt    DateTime @default(now())
  invites      InviteToken[]
  refreshTokens RefreshToken[]
  enrollments  Enrollment[]
  announcements Announcement[]
  auditLogs    AuditLog[]
}

model InviteToken {                              // fluxo: admin cria usuário -> convite -> usuário define senha
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  tokenHash String   @unique                     // armazenar hash, nunca o token puro
  purpose   String   @default("SET_PASSWORD")    // SET_PASSWORD | RESET_PASSWORD
  expiresAt DateTime
  usedAt    DateTime?
  @@index([userId])                              // reemissão/cascade filtram por userId
}

model RefreshToken {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())
  @@index([userId])                              // revogação de família + cascade filtram por userId
  @@index([expiresAt])                            // expurgo de tokens vencidos
}

model Course {
  id           String  @id @default(cuid())
  slug         String  @unique
  name         String
  totalHours   Int
  requirements CompositionRequirement[]
  milestones   Milestone[]
  subjects     Subject[]
  enrollments  Enrollment[]
}

model CompositionRequirement {                   // NC/NEO/OPT/NL/AC... flexível por curso (RF-13)
  id       String @id @default(cuid())
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId String
  key      String
  label    String
  hours    Int
  @@unique([courseId, key])
}

model Milestone {                                // CH1/CH2/CH3 (horas integralizadas)
  id          String @id @default(cuid())
  course      Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId    String
  key         String
  hours       Int
  description String
  @@unique([courseId, key])
}

model Subject {
  id        String   @id @default(cuid())
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId  String
  seq       Int                                   // nº na matriz (referência dos requisitos)
  code      String
  name      String
  hours     Int
  nucleus   Nucleus
  groupOpt  Int      @default(0)                  // 0 = obrigatória; 2..5 = grupo de optativa
  requires  Requisite[] @relation("requires")
  requiredBy Requisite[] @relation("requiredBy")
  statuses  SubjectStatus[]
  notes     SubjectNote[]
  @@unique([courseId, seq])
  @@index([courseId, groupOpt])
}

model Requisite {
  id                String   @id @default(cuid())
  subject           Subject  @relation("requires", fields: [subjectId], references: [id], onDelete: Cascade)
  subjectId         String
  requiresSubject   Subject? @relation("requiredBy", fields: [requiresSubjectId], references: [id], onDelete: Cascade)
  requiresSubjectId String?
  milestoneKey      String?                        // requisito por horas (CH1/CH2/CH3) quando não é disciplina
  type              ReqType
  @@index([subjectId])                             // loadCourseGraph faz join por subjectId; import faz deleteMany
  @@index([requiresSubjectId])
}

model Enrollment {                                 // 1 usuário pode ter N cursos (RF-13)
  id          String  @id @default(cuid())
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  course      Course  @relation(fields: [courseId], references: [id])
  courseId    String
  startTerm   String?
  currentTerm String?
  statuses    SubjectStatus[]
  extras      ExtraComponent[]
  scenarios   Scenario[]
  tasks       StudyTask[]
  notes       SubjectNote[]
  @@unique([userId, courseId])
}

model SubjectStatus {                              // APPROVED = oficial; SIMULATED = planejamento (RF-06)
  id           String       @id @default(cuid())
  enrollment   Enrollment   @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  enrollmentId String
  subject      Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  subjectId    String
  state        SubjectState
  term         String?                             // período em que cursou ("2024.1") — base do histórico
  grade        Float?                              // nota final 0..10 (RF-22: médias/MGA)
  absences     Int?                                // faltas registradas (RF-22)
  @@unique([enrollmentId, subjectId])
}

model ExtraComponent {                             // optativas fora da matriz, NL, AC, registros (RF-08/09)
  id           String        @id @default(cuid())
  enrollment   Enrollment    @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  enrollmentId String
  name         String
  code         String?
  hours        Int           @default(0)
  category     ExtraCategory
  status       ExtraStatus   @default(DONE)        // planejado | em andamento | concluído (RF-09)
  createdAt    DateTime      @default(now())
  @@index([enrollmentId])                          // list/delete filtram por enrollmentId
}

model Scenario {
  id           String   @id @default(cuid())
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  enrollmentId String
  name         String
  disciplines  ScenarioDiscipline[]
  paints       ScenarioPaint[]
  @@index([enrollmentId])                          // list de cenários filtra por enrollmentId
}

model ScenarioDiscipline {
  id         String  @id @default(cuid())
  scenario   Scenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  scenarioId String
  name       String
  sigla      String
  hours      Int     @default(0)
  docente    String?
  sigaaCode  String  @default("")
  color      String
  @@index([scenarioId])
}

model ScenarioPaint {
  id         String  @id @default(cuid())
  scenario   Scenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  scenarioId String
  cellKey    String                                 // ex.: "2-M1", "D-X3"
  category   String
  @@unique([scenarioId, cellKey])
}

// ═══ Gestão acadêmica ampliada (RF-22..27) ═══

enum Audience {
  ALL        // todos os usuários
  STUDENTS   // apenas alunos (USER)
  ADMINS     // apenas administradores
}

model Announcement {                                // RF-24: avisos/comunicados da instância
  id        String   @id @default(cuid())
  author    User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  authorId  String?
  title     String
  body      String
  audience  Audience @default(ALL)
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  @@index([createdAt])
}

enum TaskKind {
  PROVA
  TRABALHO
  ENTREGA
  OUTRO
}

model StudyTask {                                   // RF-25: agenda pessoal (provas, entregas...)
  id           String     @id @default(cuid())
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  enrollmentId String
  title        String
  kind         TaskKind   @default(OUTRO)
  dueAt        DateTime?
  done         Boolean    @default(false)
  notes        String?
  subjectCode  String?                              // referência livre à disciplina (ex.: "IME0080")
  createdAt    DateTime   @default(now())
  @@index([enrollmentId, dueAt])
}

model SubjectNote {                                 // RF-26: anotação pessoal por disciplina
  id           String     @id @default(cuid())
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  enrollmentId String
  subject      Subject    @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  subjectId    String
  text         String
  updatedAt    DateTime   @updatedAt
  @@unique([enrollmentId, subjectId])
}

model AuditLog {                                    // RF-27: trilha de auditoria (observabilidade/segurança)
  id        String   @id @default(cuid())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId    String?
  action    String                                  // "auth.login", "user.role", "course.import"...
  entity    String?
  entityId  String?
  meta      Json?
  ip        String?
  createdAt DateTime @default(now())
  @@index([createdAt])
  @@index([action])
}
