# Copie para .env e ajuste. NUNCA versione o .env real.
NODE_ENV=development

# Postgres do docker-compose (usuário/senha/db = painel)
DATABASE_URL="postgresql://painel:painel@localhost:5432/painel?schema=public"
# Conexão DIRETA usada pelas migrações (prisma migrate). Local: igual à de cima.
# Produção com Neon: DATABASE_URL = string COM -pooler (+ &pgbouncer=true) e
# DIRECT_URL = string SEM -pooler. Ver docs/DEPLOY.md.
DIRECT_URL="postgresql://painel:painel@localhost:5432/painel?schema=public"

# Segredo do JWT de acesso — mínimo 32 chars. Gere um forte:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET="troque-por-um-segredo-aleatorio-de-32+caracteres"
JWT_EXPIRES="15m"
REFRESH_EXPIRES_DAYS=14
INVITE_EXPIRES_HOURS=72

# URLs
APP_URL="http://localhost:5173"      # base dos links de convite/reset
CORS_ORIGIN="http://localhost:5173"  # origem do frontend

# Rate limit global (as rotas de auth têm limite próprio, mais agressivo)
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW="1 minute"
# Teto das rotas que aceitam segredo (login/convite/reset), por IP. Não afrouxe em produção;
# a suíte E2E sobe este valor porque faz muitos logins seguidos do mesmo endereço.
AUTH_RATE_LIMIT_MAX=10

# Usado só pelo seed (npm run seed). Não fica no schema de env da aplicação.
# SEED_ADMIN_PASSWORD é a senha inicial de painel@admin.com (e o fallback das contas-aluno);
# SEED_STUDENT_PASSWORD (opcional) define a senha das contas de src/seed/students.json.
# Todas podem ser trocadas depois em Ajustes › Senha (POST /me/password).
SEED_ADMIN_PASSWORD="defina-uma-senha-forte-de-10+caracteres"
# SEED_STUDENT_PASSWORD="defina-uma-senha-forte-de-10+caracteres"

# Banco dedicado para os testes de integração (evita poluir o de desenvolvimento).
# Aponte para um DB separado já migrado; se ausente, os testes usam DATABASE_URL.
# TEST_DATABASE_URL="postgresql://painel:painel@localhost:5432/painel_test?schema=public"

# Rate limit distribuído (escala em réplicas). Se definido, usa Redis como store; senão, memória.
# REDIS_URL="redis://localhost:6379"

# Cadastro público (RF-17). "false" = instância fechada (só entra por convite do admin).
ALLOW_REGISTRATION="true"

# Cookies do refresh. "lax" = mesma origem (Caddy/local). "none" = frontend e API em domínios
# diferentes (Vercel + Render) — força Secure automaticamente.
COOKIE_SAMESITE="lax"
# Atrás de proxy (Render/Caddy/nginx): mantém o IP real p/ rate limit.
TRUST_PROXY="true"

# E-mail (RF-18) — opcional. Sem SMTP_HOST, convites/resets ficam no log e o link é devolvido
# ao admin p/ repasse manual. Ex.: Gmail com senha de app, Resend, Brevo (todos têm tier grátis).
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT=587
# SMTP_USER="voce@gmail.com"
# SMTP_PASS="senha-de-app"
# MAIL_FROM="Painel Acadêmico <voce@gmail.com>"

# Ferramentas de desenvolvimento (gerador de alunos fictícios em /admin/dev). NUNCA em produção:
# além desta flag, o endpoint recusa quando NODE_ENV=production.
# DEV_TOOLS="true"

# Documentação OpenAPI em /docs (Swagger UI). Desligada automaticamente em produção.
DOCS_ENABLED="true"

# Camada extra de criptografia: cifra de CAMPO (AES-256-GCM) para PII em repouso — hoje o
# número de matrícula. 32 bytes em base64 ou hex. Ausente = grava em claro (modo transparente,
# retrocompatível com bases existentes). Gere com:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# ATENÇÃO: perder a chave torna as matrículas já cifradas irrecuperáveis. Guarde-a no cofre.
# FIELD_ENCRYPTION_KEY="cole-aqui-32-bytes-em-base64"

# Pool de conexões do Prisma (produção com muitas réplicas / atrás de PgBouncer):
# acrescente à DATABASE_URL algo como &connection_limit=5&pool_timeout=10

# Namespace duplo: além da raiz, a API responde também sob este prefixo (ex.: /api/auth).
# Obrigatório quando frontend e API dividem a MESMA origem (docker-compose atrás do Caddy):
# as páginas do Next em /admin/* colidem com os endpoints em /admin/*.
# Deploy cross-origin (Vercel + Render) não precisa — "" desliga.
API_ALIAS_PREFIX="/api"
