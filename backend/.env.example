# ==== Backend — variáveis de ambiente ====
# Copie para backend/.env e preencha. NÃO versione o .env real.

# Conexão PostgreSQL (ajuste usuário/senha/host conforme seu docker-compose)
DATABASE_URL="postgresql://painel:painel@localhost:5432/painel?schema=public"

# Segredo do JWT. GERE um valor aleatório e cole o RESULTADO aqui (mínimo 32 caracteres).
# Gere com um destes comandos no terminal (o resultado é o que vai entre as aspas):
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
#   openssl rand -base64 48
JWT_SECRET="COLE_AQUI_UM_SEGREDO_ALEATORIO_COM_32_OU_MAIS_CARACTERES"

JWT_EXPIRES="15m"
REFRESH_EXPIRES_DAYS="14"
CORS_ORIGIN="http://localhost:5173"
RATE_LIMIT_MAX="120"
RATE_LIMIT_WINDOW="1 minute"

# Senha do admin criada pelo seed (>= 10 caracteres). Defina ao rodar o seed, não deixe fixo aqui.
SEED_ADMIN_PASSWORD=""
